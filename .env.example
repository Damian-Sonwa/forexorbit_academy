# --- Password reset: SMS OTP (required for forgot-password) ---
# Provider: twilio (default) or termii
SMS_PROVIDER=twilio

# Default country when users omit country code (ISO 3166-1 alpha-2)
SMS_DEFAULT_REGION=NG
# Same default for browser signup/login phone validation (must match SMS_DEFAULT_REGION in production)
# NEXT_PUBLIC_PHONE_DEFAULT_REGION=NG

# Twilio — https://www.twilio.com/docs/sms
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# E.164 sender, e.g. +15551234567
TWILIO_PHONE_NUMBER=

# Termii (e.g. Nigeria) — https://termii.com
# TERMII_API_KEY=
# TERMII_SENDER_ID=ForexOrbit

# If the browser loads the app from Vercel but API calls go to Render, set the Render URL so
# forgot-password hits the server where TWILIO_* / TERMII_* are defined:
# NEXT_PUBLIC_API_BASE_URL=https://your-service.onrender.com/api

# Public app URL (optional; used elsewhere)
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Optional: Resend for other features (e.g. future certificate email)
# RESEND_API_KEY=
# RESEND_FROM=

# --- Lesson monetization (Paystack) ---
# Secret: server only. Public key: exposed to browser for inline checkout.
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
# Price per paid lesson in kobo (e.g. 200000 = ₦2,000)
PAYSTACK_LESSON_PRICE_KOBO=200000
PAYSTACK_CURRENCY=NGN

# --- Ads: PropellerAds on free first lesson + demo tasks only (paid lessons: no ads) ---
# NEXT_PUBLIC_ADS_ENABLED=true
# propellerads | adsense | admob | none
# NEXT_PUBLIC_ADS_PROVIDER=propellerads
#
# Option A — one widget script (Propeller “Get code” URL). Used for top banner if set:
# NEXT_PUBLIC_PROPELLERADS_WIDGET_SCRIPT_URL=https://...
#
# Option B — shared library + zone id (ins[data-zoneid]):
# NEXT_PUBLIC_PROPELLERADS_LIBRARY_SCRIPT_URL=https://...
# NEXT_PUBLIC_PROPELLERADS_ZONE_ID=your_zone_id
# Optional class on <ins> from Propeller:
# NEXT_PUBLIC_PROP_PLACEMENT_LESSON_TOP_INS_CLASS=
#
# Per-surface overrides (see lib/propeller-ads-placements.ts):
# NEXT_PUBLIC_PROP_PLACEMENT_LESSON_TOP_SCRIPT=
# NEXT_PUBLIC_PROP_PLACEMENT_LESSON_INLINE_SCRIPT=
# NEXT_PUBLIC_PROP_PLACEMENT_DEMO_TASKS_SCRIPT=
# NEXT_PUBLIC_PROP_PLACEMENT_INTERSTITIAL_SCRIPT=
# (or _LIB / _ZONE / _INS_CLASS variants for each placement)
#
# Legacy Google:
# NEXT_PUBLIC_ADSENSE_CLIENT=
# NEXT_PUBLIC_ADSENSE_BANNER_SLOT=
# NEXT_PUBLIC_ADMOB_WEB_BANNER_SLOT=
